              "let responseJson;",
              "try {",
              "    responseJson = pm.response.json();",
              "} catch (e) {",
              "    console.warn('Response is not valid JSON.');",
              "}",
              "",
              "if (responseJson && responseJson._id) {",
              "    pm.environment.set('client_ID', responseJson._id);",
              "} else {",
              "    console.warn(\"Response JSON does not contain '_id'.\");",
              "}"
