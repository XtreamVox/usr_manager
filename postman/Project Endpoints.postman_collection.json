      "name": "Create Project",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson;\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    console.warn('Response is not valid JSON.');\r",
              "}\r",
              "\r",
              "if (responseJson && responseJson._id) {\r",
              "    pm.environment.set('project_ID', responseJson._id);\r",
              "} else {\r",
              "    console.warn(\"Response JSON does not contain '_id'.\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
