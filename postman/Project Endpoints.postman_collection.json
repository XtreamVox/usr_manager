          "raw": "{\r\n  \"name\": \"Proyecto Demo\",\r\n  \"client\": \"{{client_ID}}\",\r\n  \"email\": \"contacto@empresa.com\",\r\n  \"notes\": \"Proyecto creado desde Postman para pruebas\",\r\n  \"active\": true,\r\n  \"address\": {\r\n    \"street\": \"Calle Mayor\",\r\n    \"number\": \"123\",\r\n    \"postal\": \"28001\",\r\n    \"city\": \"Madrid\",\r\n    \"province\": \"Madrid\"\r\n  }\r\n}",
